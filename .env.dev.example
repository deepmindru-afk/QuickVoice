# Root development orchestration settings used by Taskfile and scripts.
COMPOSE_PROJECT_NAME=quickvoice-dev

SERVER_PORT=5000
CONSOLE_PORT=3000
WEB_PORT=3001
POSTGRES_PORT=5432
REDIS_PORT=6379

AI_API_ENABLED=true
AI_API_PORT=5555
AI_WORKER_ENABLED=false

# Docker Compose uses dev-only credentials and binds database services to
# localhost. Replace service-specific generated env files before sharing data.
POSTGRES_USER=quickvoice
POSTGRES_PASSWORD=quickvoice
POSTGRES_DB=quickvoice
REDIS_URL=redis://localhost:6379
