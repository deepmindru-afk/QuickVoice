{
  "name": "QuickVoice",
  "description": "Source-available AI voice agent platform for automating phone calls, scheduling, support, reminders, and sales workflows.",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://quickvoice.co",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/allgpt-co/QuickVoice.git"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test:dev-orchestration": "node --test tests/dev-orchestration.test.mjs"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.20",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "better-auth": "^1.6.2"
  }
}
