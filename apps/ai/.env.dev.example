AI_API_HOST=0.0.0.0
AI_API_PORT=5555
AI_API_RELOAD=true

SERVER_API_URL=http://localhost:5000/api/v1
INTERNAL_API_KEY=dev-internal-key-change-me

LIVEKIT_URL=wss://your-livekit-host
LIVEKIT_API_KEY=dev-livekit-api-key
LIVEKIT_API_SECRET=dev-livekit-api-secret
LIVEKIT_AGENT_NAME=QuickVoice
LIVEKIT_TURN_DOMAIN=turn.your-livekit-host

VOICE_CATALOG_PATH=
LLM_PROVIDER=bedrock_sdk
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_FALLBACK_MODEL_ID=us.amazon.nova-micro-v1:0
BEDROCK_TIMEOUT_MS=30000
DEEPGRAM_API_KEY=
DEEPGRAM_DEFAULT_MODEL=nova-3
DEEPGRAM_DEFAULT_LANGUAGE=en
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_MODEL=eleven_flash_v2_5
ELEVENLABS_DEFAULT_VOICE_ID=EXAVITQu4vr4xnSDxMaL
SARVAM_API_KEY=
SARVAM_DEFAULT_STT_MODEL=saaras:v3
SARVAM_DEFAULT_TTS_MODEL=bulbul:v3
SARVAM_DEFAULT_LANGUAGE=en-IN
SARVAM_DEFAULT_SPEAKER=shubh
ENABLE_INTERRUPTS=true
SESSION_TOKEN_TTL_SECONDS=900
SESSION_ROOM_PREFIX=voice-

AWS_ACCESS_KEY_ID=dev-s3-access-key
AWS_SECRET_ACCESS_KEY=dev-s3-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=quickvoice-dev

