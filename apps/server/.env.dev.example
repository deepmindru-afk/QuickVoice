NODE_ENV=development
API_VERSION=v1
PORT=5000
SERVER_URL=http://localhost:5000
CONSOLE_URL=http://localhost:3000
WEB_URL=http://localhost:3001

# Dev-only Docker Compose credentials. Do not reuse these outside local setup.
DATABASE_URL=postgresql://quickvoice:quickvoice@localhost:5432/quickvoice
REDIS_URL=redis://localhost:6379
LIVE_TRANSCRIPT_TTL_SECONDS=3600
WIDGET_ASSET_DIR=../widget/dist
WIDGET_SESSION_TTL_SECONDS=900
WIDGET_RATE_LIMIT_WINDOW_SECONDS=60
WIDGET_RATE_LIMIT_MAX_SESSIONS=10
WIDGET_MAX_CONCURRENT_SESSIONS_PER_WIDGET=5
WIDGET_ALLOW_LOCALHOST_ORIGINS=true

BETTER_AUTH_URL=http://localhost:5000
BETTER_AUTH_SECRET=dev-better-auth-secret-change-me-32chars
INTERNAL_API_KEY=dev-internal-key-change-me

GOOGLE_CLIENT_ID=dev-google-client-id
GOOGLE_CLIENT_SECRET=dev-google-client-secret

LIVEKIT_URL=wss://your-livekit-host
LIVEKIT_API_KEY=dev-livekit-api-key
LIVEKIT_API_SECRET=dev-livekit-api-secret
LIVEKIT_AGENT_NAME=quickvoice-voice-agent
LIVEKIT_SIP_INBOUND_TRUNK_ID=dev-inbound-trunk
LIVEKIT_SIP_OUTBOUND_TRUNK_TWILIO_ID=dev-twilio-trunk
LIVEKIT_SIP_OUTBOUND_TRUNK_TELNYX_ID=dev-telnyx-trunk

TWILIO_ACCOUNT_SID=AC00000000000000000000000000000000
TWILIO_AUTH_TOKEN=dev-twilio-auth-token
TWILIO_TRUNK_SID=dev-twilio-trunk-sid
TELNYX_API_KEY=dev-telnyx-api-key
TELNYX_CONNECTION_ID=dev-telnyx-connection-id

AWS_ACCESS_KEY_ID=dev-s3-access-key
AWS_SECRET_ACCESS_KEY=dev-s3-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=quickvoice-dev

STRIPE_SECRET_KEY=sk_test_dev_placeholder
STRIPE_WEBHOOK_SECRET=whsec_dev_placeholder

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=dev
SMTP_PASSWORD=dev
FROM_EMAIL=no-reply@localhost

SMITHERY_NAMESPACE=quickvoice
SMITHERY_API_KEY=dev-smithery-key
