generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum sourceType {
  PDF
  TXT
  CSV
  DOCX
  XLSX
  XLS
  URL
}

enum CallStatus {
  NOT_ANSWERED
  SCHEDULED
  PROCESSED
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum CampaignStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
  PROCESSED
  FAILED
}

enum kbStatus {
  PROCESSING
  ACTIVE
  ERROR
}

enum OutboundCallMode {
  quick
  campaign
}

enum PlanId {
  free
  payg
  starter
  growth
  scale
  enterprise
  admin
}

enum TelephonyProvider {
  TWILIO @map("twilio")
  TELNYX @map("telnyx")
}

enum McpConnectionStatus {
  PENDING
  CONNECTED
  AUTH_REQUIRED
  INPUT_REQUIRED
  ERROR
  DISCONNECTED
}

enum McpCatalogSource {
  SMITHERY
  CUSTOM
}

enum AgentWidgetSessionStatus {
  CREATED
  ACTIVE
  ENDED
  EXPIRED
  FAILED
}

// ─── Better Auth Core Tables ─────────────────────────────────────────────────

model User {
  id               String       @id
  name             String
  email            String
  emailVerified    Boolean      @default(false)
  image            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  role             String?
  banned           Boolean?     @default(false)
  banReason        String?
  banExpires       DateTime?
  stripeCustomerId String?
  sessions         Session[]
  accounts         Account[]
  members          Member[]
  invitations      Invitation[]

  // App resource reverse relations
  phoneNumbers     PhoneNumber[]
  agents           Agent[]
  knowledgeSources KnowledgeSource[]
  callLogs         CallLog[]
  outboundCalls    OutboundCall[]
  campaigns        Campaign[]
  tools            Tool[]
  mcpConnections   McpConnection[]
  secrets          Secret[]
  auditLogs        AuditLog[]

  @@unique([email])
}

model Session {
  id                   String   @id
  expiresAt            DateTime
  token                String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  ipAddress            String?
  userAgent            String?
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy       String?
  activeOrganizationId String?

  @@unique([token])
  @@index([userId])
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

// ─── Better Auth Plugin Tables ───────────────────────────────────────────────

model Apikey {
  id                  String    @id
  configId            String    @default("default")
  name                String?
  start               String?
  referenceId         String
  prefix              String?
  key                 String
  refillInterval      Int?
  refillAmount        Int?
  lastRefillAt        DateTime?
  enabled             Boolean?  @default(true)
  rateLimitEnabled    Boolean?  @default(true)
  rateLimitTimeWindow Int?      @default(86400000)
  rateLimitMax        Int?      @default(10)
  requestCount        Int?      @default(0)
  remaining           Int?
  lastRequest         DateTime?
  expiresAt           DateTime?
  createdAt           DateTime
  updatedAt           DateTime
  permissions         String?
  metadata            String?

  @@index([configId])
  @@index([referenceId])
  @@index([key])
}

// ─── Organization & Team ─────────────────────────────────────────────────────

model Organization {
  id                String             @id
  name              String
  slug              String
  logo              String?
  createdAt         DateTime
  metadata          String?
  stripeCustomerId  String?
  members           Member[]
  invitations       Invitation[]
  accessKey         String?
  plan              PlanId             @default(free)
  agents            Agent[]
  agentWidgets      AgentWidget[]
  knowledgeSources  KnowledgeSource[]
  phoneNumbers      PhoneNumber[]
  tools             Tool[]
  mcpConnections    McpConnection[]
  mcpCatalogItems   McpServerCatalogItem[]
  agentMcpConnections AgentMcpConnection[]
  mcpToolExecutionLogs McpToolExecutionLog[]
  secrets           Secret[]
  callLogs          CallLog[]
  outboundCalls     OutboundCall[]
  campaigns         Campaign[]
  organizationroles OrganizationRole[]
  auditLogs         AuditLog[]

  @@unique([slug])
  @@index([stripeCustomerId])
}

model OrganizationRole {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           String
  permission     String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime?    @updatedAt

  @@index([organizationId])
  @@index([role])
}

model Member {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String       @default("member")
  createdAt      DateTime

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

model Invitation {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String       @default("pending")
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@index([inviterId])
}

// ─── Billing (Better Auth Stripe Plugin) ─────────────────────────────────────

model Subscription {
  id                   String    @id
  plan                 String
  referenceId          String
  stripeCustomerId     String?
  stripeSubscriptionId String?
  status               String?   @default("incomplete")
  periodStart          DateTime?
  periodEnd            DateTime?
  trialStart           DateTime?
  trialEnd             DateTime?
  cancelAtPeriodEnd    Boolean?  @default(false)
  cancelAt             DateTime?
  canceledAt           DateTime?
  endedAt              DateTime?
  seats                Int?
  billingInterval      String?
  stripeScheduleId     String?

  @@index([referenceId])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@index([status])
}

// ─── App Resource Models ─────────────────────────────────────────────────────

model PhoneNumber {
  phId           String            @id @default(uuid())
  number         String            @unique
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  agentId        String?
  agent          Agent?            @relation(fields: [agentId], references: [agentId], onDelete: SetNull)
  sid            String
  friendlyName   String
  provider       TelephonyProvider @default(TWILIO)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([organizationId])
  @@index([agentId])
  @@index([userId])
  @@index([sid])
}

model Agent {
  agentId               String              @id @default(uuid())
  agentSlug             String
  organizationId        String
  organization          Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId                String?
  user                  User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  name                  String
  templateId            String?
  isActive              Boolean             @default(true)
  // TODO : Change in backend and frontend
  isConfigured          Boolean             @default(false)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  configuration         AgentConfiguration?
  widgets               AgentWidget[]
  // TODO : Change in API, removed callLog[]
  callLogsCount         Int                 @default(0)
  callLogs              CallLog[]
  phoneNumbers          PhoneNumber[]
  knowledgeSources      KnowledgeSource[]
  outboundCalls         OutboundCall[]
  campaigns             Campaign[]
  // TODO : Change in API also fetch in agent config page, removed knowledgeSources[]
  knowledgeSourcesCount Int                 @default(0)
  // TODO:Change in API, removed phoneNumbers[]
  phoneNumbersCount     Int                 @default(0)
  // TODO: Fetch tools in agent config, removed tools[]
  toolsCount            Int                 @default(0)

  tools Tool[] @relation("AgentTools")
  mcpConnections AgentMcpConnection[]
  mcpToolExecutionLogs McpToolExecutionLog[]

  @@unique([organizationId, agentSlug])
  @@index([userId])
  @@index([organizationId, createdAt])
}

model AgentConfiguration {
  agentConfigId                     String   @id @default(uuid())
  agentId                           String   @unique
  agent                             Agent    @relation(fields: [agentId], references: [agentId], onDelete: Cascade)
  systemPrompt                      String
  firstMessage                      String
  temperature                       Float    @default(0.7)
  data_needed                       Json?    @default("[]")
  data_evaluation                   Json?    @default("[]")
  // TODO: Add voiceId to the enum
  voiceId                           String
  concurrent_calls_limit            Int
  conversation_retention_days       Int      @default(30)
  daily_calls_limit                 Int
  enable_auth_for_agent_api         Boolean  @default(false)
  max_conversation_duration_seconds Int
  optimize_streaming_latency        Boolean  @default(false)
  silence_end_call_timeout_seconds  Int
  store_call_audio                  Boolean  @default(true)
  tokenLimit                        Int      @default(4096)
  tts_output_format                 String   @default("mp3")
  turn_timeout_seconds              Int
  update_at                         DateTime @updatedAt
  use_flash_call                    Boolean  @default(false)
  use_rag                           Boolean  @default(false)
  user_input_audio_format           String
  voice_similarity_boost            Float
  voice_speed                       Float
  voice_stability                   Float
  zero_pii_retention                Boolean  @default(false)
  llmModel                          String   @default("gpt-4o-mini")
  sttModel                          String   @default("nova-3")
  ttsModel                          String   @default("aura-2")
  agent_language                    String   @default("en")
  initiation_webhook                Json?
  post_call_webhook                 Json?
  variables                         Json?
  preemptive_generation             Boolean  @default(false)
  ivr_navigation_enabled            Boolean  @default(true)
  timezone                          String   @default("UTC")
}

model AgentWidget {
  widgetId        String       @id
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agentId         String
  agent           Agent        @relation(fields: [agentId], references: [agentId], onDelete: Cascade)
  name            String
  enabled         Boolean      @default(false)
  allowedOrigins  Json         @default("[]")
  theme           Json         @default("{}")
  consentRequired Boolean      @default(true)
  consentText     String?
  createdByUserId String?
  updatedByUserId String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  sessions        AgentWidgetSession[]

  @@index([organizationId])
  @@index([agentId])
  @@index([organizationId, agentId])
  @@index([enabled])
}

model AgentWidgetSession {
  sessionId           String                   @id
  widgetId            String
  widget              AgentWidget              @relation(fields: [widgetId], references: [widgetId], onDelete: Cascade)
  organizationId      String
  agentId             String
  roomName            String                   @unique
  callId              String?
  participantIdentity String
  dispatchId          String?
  origin              String?
  status              AgentWidgetSessionStatus @default(CREATED)
  endTokenHash        String?
  expiresAt           DateTime
  startedAt           DateTime?
  endedAt             DateTime?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  metadata            Json?

  @@index([widgetId])
  @@index([organizationId])
  @@index([agentId])
  @@index([organizationId, status])
  @@index([expiresAt])
}

model KnowledgeSource {
  kbId             String       @id @default(uuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agentId          String?
  agent            Agent?       @relation(fields: [agentId], references: [agentId], onDelete: SetNull)
  userId           String?
  user             User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  name             String
  originalFileName String?
  storagePath      String
  sourceType       sourceType
  status           kbStatus
  metadata         Json?
  lastIndexedAt    DateTime?
  uploadedAt       DateTime     @default(now())

  @@index([organizationId])
  @@index([agentId])
  @@index([userId])
  @@index([organizationId, status])
}

// ─── Call & Conversation Models ──────────────────────────────────────────────

model CallLog {
  callId         String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agentId        String?
  agent          Agent?       @relation(fields: [agentId], references: [agentId], onDelete: SetNull)
  userId         String?
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Call Data
  startTime          DateTime?
  endTime            DateTime?
  durationSeconds    Int?
  status             CallStatus
  audioRecordingPath String?
  callerId           String?
  metadata           Json?
  sessionId          String?
  direction          String?
  dataExtracted      Json?            @default("[]")
  dataEvaluation     Json?            @default("[]")
  // Future-use fields
  callCostCents      Int?
  // TODO Remove include transcripts from api call
  transcripts        CallTranscript[]
  // TODO Change in api for delete and fetch credits
  deleted            Boolean          @default(false)
  outbound           OutboundCall?    

  @@index([organizationId])
  @@index([organizationId, startTime])
  @@index([organizationId, endTime])
  @@index([agentId])
  @@index([userId])
}

model CallTranscript {
  callTransId     String   @id @default(uuid())
  callLogId       String
  callLog         CallLog  @relation(fields: [callLogId], references: [callId], onDelete: Cascade)
  speaker         String
  messageText     String
  timestamp       DateTime
  confidenceScore Float?
  isPiiRedacted   Boolean  @default(false)
  sentimentScore  Float?

  @@index([callLogId])
}

model OutboundCall {
  outboundId     String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agentId        String?
  agent          Agent?       @relation(fields: [agentId], references: [agentId], onDelete: SetNull)
  userId         String?
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  campaignId     String?
  campaign       Campaign?    @relation(fields: [campaignId], references: [campaignId], onDelete: SetNull)
  scheduledAt    DateTime?
  callLogId      String?        @unique
  callLog        CallLog?       @relation(fields: [callLogId], references: [callId], onDelete: SetNull)
  // Call Data
  phoneNumber  String
  fromNumber   String
  firstMessage String?
  systemPrompt String?
  optionalData Json?            @default("{}")
  mode         OutboundCallMode
  status       CallStatus
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([organizationId])
  @@index([agentId])
  @@index([campaignId])
  @@index([userId])
  @@index([status, scheduledAt])
}

model Campaign {
  campaignId     String         @id @default(uuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  agentId        String?
  agent          Agent?         @relation(fields: [agentId], references: [agentId], onDelete: SetNull)
  fromNumber     String
  scheduledAt    DateTime?
  sourceFileKey  String?
  sourceFileName String?
  totalRecipients Int          @default(0)
  validRecipients Int          @default(0)
  invalidRecipients Int        @default(0)
  ringingTimeoutSeconds Int    @default(60)
  timezone       String        @default("UTC")
  status         CampaignStatus
  startedAt      DateTime?
  completedAt    DateTime?
  userId         String?
  user           User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  outboundCalls  OutboundCall[]

  @@index([organizationId])
  @@index([agentId])
  @@index([userId])
  @@index([status, scheduledAt])
}

// ─── Config & Secrets ────────────────────────────────────────────────────────

model Tool {
  toolId                String       @id @default(uuid())
  organizationId        String
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name                  String
  description           String
  disable_interruptions Boolean      @default(false)
  force_pre_tool_speech Boolean      @default(true)
  api_url               String
  api_method            String?      @default("POST")
  api_headers           Json?
  api_body              Json?
  api_query_params      Json?
  api_path_params       Json?
  response_timeout_secs Int?
  dynamic_variables     Json?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  userId                String?
  user                  User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  agent                 Agent[]      @relation("AgentTools")

  @@index([organizationId])
  @@index([userId])
}

model McpServerCatalogItem {
  mcpServerId     String           @id @default(uuid())
  organizationId  String?
  organization    Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  slug            String
  name            String
  description     String
  source          McpCatalogSource @default(SMITHERY)
  provider        String           @default("smithery")
  mcpUrl          String
  smitheryServerKey String?
  authType        String           @default("oauth")
  categories      Json?            @default("[]")
  verified        Boolean          @default(false)
  toolCount       Int              @default(0)
  metadata        Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  connections     McpConnection[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([source])
  @@index([verified])
}

model McpConnection {
  mcpConnectionId       String              @id @default(uuid())
  organizationId        String
  organization          Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId                String?
  user                  User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  catalogItemId         String?
  catalogItem           McpServerCatalogItem? @relation(fields: [catalogItemId], references: [mcpServerId], onDelete: SetNull)
  displayName           String
  provider              String              @default("smithery")
  mcpUrl                String
  smitheryNamespace     String
  smitheryConnectionId  String
  status                McpConnectionStatus @default(PENDING)
  setupUrl              String?
  tools                 Json?               @default("[]")
  metadata              Json?
  lastSyncedAt          DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  agents                AgentMcpConnection[]
  executionLogs         McpToolExecutionLog[]

  @@unique([organizationId, smitheryConnectionId])
  @@index([organizationId])
  @@index([userId])
  @@index([status])
}

model AgentMcpConnection {
  agentMcpConnectionId String        @id @default(uuid())
  organizationId       String
  organization         Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agentId              String
  agent                Agent         @relation(fields: [agentId], references: [agentId], onDelete: Cascade)
  mcpConnectionId      String
  mcpConnection        McpConnection @relation(fields: [mcpConnectionId], references: [mcpConnectionId], onDelete: Cascade)
  enabled              Boolean       @default(true)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@unique([agentId, mcpConnectionId])
  @@index([organizationId])
  @@index([mcpConnectionId])
}

model McpToolExecutionLog {
  mcpToolExecutionLogId String        @id @default(uuid())
  organizationId        String
  organization          Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agentId               String?
  agent                 Agent?        @relation(fields: [agentId], references: [agentId], onDelete: SetNull)
  mcpConnectionId       String
  mcpConnection         McpConnection @relation(fields: [mcpConnectionId], references: [mcpConnectionId], onDelete: Cascade)
  toolName              String
  callId                String?
  status                String
  latencyMs             Int?
  argumentsPreview      Json?
  resultPreview         Json?
  error                 String?
  createdAt             DateTime      @default(now())

  @@index([organizationId])
  @@index([agentId])
  @@index([mcpConnectionId])
  @@index([createdAt])
}

model Secret {
  secretId       String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  value          String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  userId         String?
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([userId])
}

model AuditLog {
  auditLogId     String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  action         String
  resourceType   String
  resourceId     String?
  metadata       Json?
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
  @@index([userId])
  @@index([action])
}
